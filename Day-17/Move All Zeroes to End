class Solution {
    void pushZerosToEnd(int[] arr) {
        int n = arr.length;
        int low = 0;  
        int high = 0;  
        while (high < n) {
            if (arr[high] != 0) {
                int temp = arr[low];
                arr[low] = arr[high];
                arr[high] = temp;
                
                low++;
            }
            high++;
        }
    }
}
