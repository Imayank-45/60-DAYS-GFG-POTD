class Solution {
    public int hIndex(int[] citations) {
        // code here
        int result=0;
        int n=citations.length;
        Arrays.sort(citations);
        for(int i=n-1;i>=0;i--){
           //int temp=n-i;
           if(n-i<=citations[i]) result++;
        }
        return result;
    }
}
