class Solution {
    public int longestSubarray(int[] arr, int k) {
        // Code Here
        int n=arr.length;
        int result=0;
        for(int i=0;i<n;i++){
            int count=0;
            for(int j=i;j<n;j++){
               if(arr[j]>k)  count++;
               else count--;
               if(count>0) result=Math.max(result,j-i+1);
            }
        }
        return result;
    }
}
