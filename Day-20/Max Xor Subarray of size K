class Solution {
    public int maxSubarrayXOR(int[] arr, int k) {
        int n = arr.length;
        int xor = 0;
        for(int i = 0; i < k; i++) xor ^= arr[i];
        int maxXor = xor;
        for(int i = 1; i <= n - k; i++){
            xor = xor ^ arr[i-1];     
            xor = xor ^ arr[i+k-1];    
            maxXor = Math.max(maxXor, xor);
        }
        return maxXor;
    }
}
