class Solution {
    public long subarrayXor(int arr[], int k) {
        // code here
        int count =0,n=arr.length;
        for(int i=0;i<n;i++){
            int XOR=0;
            for(int j=i;j<n;j++){
                XOR^=arr[j];
                if(XOR==k){
                    count++;
                }
            }
        }
        return count;
    }
}
